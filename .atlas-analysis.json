  "keyFeatures": [
    "Chaos injection for failures, delays, and timeouts",
    "Network simulation (latency, packet loss, DNS failures)",
    "HTTP chaos (status codes, rate limits, server errors)",
    "Stream manipulation (cuts, pauses, corruption)",
    "AI SDK v6 integration with models, providers, and middleware",
    "Resilience patterns (circuit breaker, retry, bulkhead, fallback)",
    "Fetch interception for global chaos",
    "Presets and scenarios for common failure modes",
    "Statistics and event tracking",
    "CLI tool for endpoint testing and benchmarking",
    "Deterministic mode with seeding",
    "TypeScript native with zero dependencies"
  ],
